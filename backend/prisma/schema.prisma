generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



model Quiz {
  id        Int        @id @default(autoincrement())
  title     String
  questions Question[]
  createdAt DateTime   @default(now())
}

model Question {
  id         Int           @id @default(autoincrement())
  quiz       Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId     Int
  type       QuestionType
  text       String
  options    String[]      @default([])
  correct    String[]      @default([])
}

enum QuestionType {
  BOOLEAN
  INPUT
  CHECKBOX
}
